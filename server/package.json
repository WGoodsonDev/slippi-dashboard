{
    "name": "@slippi-dashboard/server",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "nodemon --exec tsx src/index.ts",
        "build": "prisma generate && tsc",
        "start": "prisma migrate deploy && node dist/index.js",
        "test": "vitest run",
        "migrate": "prisma migrate dev"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1012.0",
        "@aws-sdk/lib-storage": "^3.1012.0",
        "@clerk/express": "^2.0.4",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@slippi/slippi-js": "^9.0.0",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^5.2.1",
        "multer": "^2.1.1",
        "pg": "^8.20.0",
        "prisma": "^7.5.0",
        "typescript": "~5.9.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/pg": "^8.11.11",
        "@types/supertest": "^7.2.0",
        "nodemon": "^3.1.14",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "vitest": "^4.1.0"
    }
}
